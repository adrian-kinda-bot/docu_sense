<!DOCTYPE html>
<html class="h-full bg-gray-50">
  <head>
    <title><%= content_for(:title) || "Docu Sense" %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="mobile-web-app-capable" content="yes">
    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="h-full font-sans antialiased">
    <% if user_signed_in? %>
      <%= render "shared/sidebar" %>
    <% end %>

    <main class="<%= user_signed_in? ? "lg:ml-[250px]" : "" %> min-h-screen">
      <!-- Flash Messages -->
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
        <% if notice %>
          <div class="mb-6 bg-emerald-50 border border-emerald-200 text-emerald-800 px-4 py-3 rounded-xl shadow-sm" role="alert">
            <div class="flex items-center">
              <svg class="h-5 w-5 text-emerald-400 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zm3.707-9.293a1 1 0 00-1.414-1.414L9 10.586 7.707 9.293a1 1 0 00-1.414 1.414l2 2a1 1 0 001.414 0l4-4z" clip-rule="evenodd" />
              </svg>
              <span class="text-sm font-medium"><%= notice %></span>
            </div>
          </div>
        <% end %>

        <% if alert %>
          <div class="mb-6 bg-red-50 border border-red-200 text-red-800 px-4 py-3 rounded-xl shadow-sm" role="alert">
            <div class="flex items-center">
              <svg class="h-5 w-5 text-red-400 mr-2" fill="currentColor" viewBox="0 0 20 20">
                <path fill-rule="evenodd" d="M10 18a8 8 0 100-16 8 8 0 000 16zM8.707 7.293a1 1 0 00-1.414 1.414L8.586 10l-1.293 1.293a1 1 0 101.414 1.414L10 11.414l1.293 1.293a1 1 0 001.414-1.414L11.414 10l1.293-1.293a1 1 0 00-1.414-1.414L10 8.586 8.707 7.293z" clip-rule="evenodd" />
              </svg>
              <span class="text-sm font-medium"><%= alert %></span>
            </div>
          </div>
        <% end %>
      </div>

      <%= yield %>
    </main>

    <!-- Title Edit Modal -->
    <div id="titleEditModal" class="fixed inset-0 bg-gray-600 bg-opacity-50 hidden z-50" data-controller="modal">
      <div class="flex items-center justify-center min-h-screen p-4">
        <div class="bg-white rounded-lg shadow-xl max-w-md w-full p-6" data-modal-target="content">
          <h3 class="text-lg font-semibold text-gray-900 mb-4">Rename Chat</h3>
          <form id="titleEditForm" class="space-y-4">
            <div>
              <label for="chatTitle" class="block text-sm font-medium text-gray-700 mb-2">Chat Title</label>
              <input type="text"
                     id="chatTitle"
                     name="title"
                     class="w-full px-3 py-2 border border-gray-300 rounded-md shadow-sm focus:ring-blue-500 focus:border-blue-500"
                     placeholder="Enter chat title">
            </div>
            <div class="flex justify-end space-x-3">
              <button type="button"
                      class="px-4 py-2 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-md hover:bg-gray-50"
                      data-action="click->modal#hide">
                Cancel
              </button>
              <button type="submit"
                      class="px-4 py-2 text-sm font-medium text-white bg-blue-600 border border-transparent rounded-md hover:bg-blue-700">
                Save
              </button>
            </div>
          </form>
        </div>
      </div>
    </div>



    <style>
      /* Basic dropdown styling */
      [data-dropdown-target="menu"] {
        z-index: 9999 !important;
        position: absolute !important;
        background: white !important;
        border: 1px solid #e5e7eb !important;
        border-radius: 0.5rem !important;
        box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.1), 0 4px 6px -2px rgba(0, 0, 0, 0.05) !important;
        min-width: 128px !important;
      }
    </style>

    <script>
      // Title edit functionality
      function editChatTitle(chatId, currentTitle) {
        const modal = document.getElementById('titleEditModal');
        const titleInput = document.getElementById('chatTitle');
        const form = document.getElementById('titleEditForm');

        titleInput.value = currentTitle;
        modal.classList.remove('hidden');

        form.onsubmit = function(e) {
          e.preventDefault();

          fetch(`/chat_sessions/${chatId}`, {
            method: 'PATCH',
            headers: {
              'Content-Type': 'application/json',
              'X-CSRF-Token': document.querySelector('meta[name="csrf-token"]').content
            },
            body: JSON.stringify({
              chat_session: {
                title: titleInput.value
              }
            })
          })
          .then(response => response.json())
          .then(data => {
            if (data.success) {
              // Update all title elements for this chat
              updateChatTitle(chatId, titleInput.value);
              modal.classList.add('hidden');
            } else {
              alert('Failed to update title: ' + (data.errors || 'Unknown error'));
            }
          })
          .catch(error => {
            console.error('Error updating chat title:', error);
            alert('Failed to update title. Please try again.');
          });
        };
      }

      // Function to update chat title in all places
      function updateChatTitle(chatId, newTitle) {
        // Update in sidebar
        const chatElement = document.querySelector(`[data-chat-id="${chatId}"]`);
        if (chatElement) {
          const titleElement = chatElement.querySelector('.chat-title');
          if (titleElement) {
            titleElement.textContent = newTitle;
            titleElement.title = newTitle;
          }
        }

        // Update in main header if this is the current chat
        const currentChatId = document.querySelector('[data-current-chat-id]')?.dataset.currentChatId;
        if (chatId === currentChatId) {
          const mainTitle = document.querySelector('.chat-title');
          if (mainTitle) {
            mainTitle.textContent = newTitle;
          }
        }
      }

      // Close modal when clicking outside
      document.addEventListener('DOMContentLoaded', function() {
        const modal = document.getElementById('titleEditModal');
        if (modal) {
          modal.addEventListener('click', function(e) {
            if (e.target === this) {
              this.classList.add('hidden');
            }
          });
        }
      });
    </script>
  </body>
</html>
