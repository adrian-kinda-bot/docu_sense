<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header Section -->
  <div class="mb-8">
    <div class="flex items-center justify-between">
      <div class="flex-1">
        <h1 class="text-3xl font-bold text-gray-900 mb-2">Chat Sessions</h1>
        <p class="text-gray-600 text-lg">Ask questions about your documents using AI</p>
      </div>
      <div class="ml-6">
        <%= link_to new_chat_session_path, class: "inline-flex items-center px-6 py-3 border border-transparent text-sm font-medium rounded-xl text-white bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200 shadow-sm hover:shadow-md" do %>
          <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
          </svg>
          New Chat
        <% end %>
      </div>
    </div>
  </div>

  <% if @chat_sessions.any? %>
    <!-- Chat Sessions Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      <% @chat_sessions.each do |session| %>
        <div class="bg-white overflow-hidden shadow-sm hover:shadow-lg transition-all duration-200 rounded-xl border border-gray-200 group">
          <div class="p-6">
            <!-- Header -->
            <div class="flex items-start justify-between mb-4">
              <h3 class="text-lg font-semibold text-gray-900 group-hover:text-blue-600 transition-colors duration-200">
                <%= link_to session.title, chat_session_path(session) %>
              </h3>
              <span class="inline-flex items-center px-2.5 py-0.5 rounded-full text-xs font-medium <%= session.status == 'active' ? 'bg-emerald-100 text-emerald-800' : 'bg-gray-100 text-gray-800' %>">
                <%= session.status.humanize %>
              </span>
            </div>

            <!-- Stats -->
            <div class="flex items-center justify-between text-sm text-gray-500 mb-4">
              <span class="flex items-center space-x-2">
                <svg class="h-4 w-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                </svg>
                <span><%= pluralize(session.chat_messages.count, 'message') %></span>
              </span>
              <span class="text-xs"><%= time_ago_in_words(session.updated_at) %> ago</span>
            </div>

            <!-- Last Message Preview -->
            <% if session.last_message %>
              <div class="mb-4">
                <p class="text-sm text-gray-600 line-clamp-2 leading-relaxed">
                  <%= session.last_message.content.truncate(120) %>
                </p>
              </div>
            <% end %>

            <!-- Actions -->
            <div class="flex items-center justify-between pt-4 border-t border-gray-100">
              <div class="flex space-x-3">
                <%= link_to "Continue", chat_session_path(session), class: "text-blue-600 hover:text-blue-800 text-sm font-medium transition-colors duration-200" %>
                <%= link_to "Delete", chat_session_path(session), method: :delete, data: { confirm: "Are you sure you want to delete this chat session?" }, class: "text-red-600 hover:text-red-800 text-sm font-medium transition-colors duration-200" %>
              </div>

              <!-- Collection info if available -->
              <% if session.document_collection %>
                <div class="flex items-center space-x-2">
                  <svg class="w-3 h-3 text-gray-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
                  </svg>
                  <span class="text-xs text-gray-500"><%= session.document_collection.name %></span>
                </div>
              <% end %>
            </div>
          </div>
        </div>
      <% end %>
    </div>
  <% else %>
    <!-- Empty State -->
    <div class="text-center py-16">
      <div class="w-20 h-20 bg-gradient-to-br from-blue-100 to-blue-200 rounded-full flex items-center justify-center mx-auto mb-6">
        <svg class="w-10 h-10 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
        </svg>
      </div>
      <h3 class="text-xl font-semibold text-gray-900 mb-2">No chat sessions yet</h3>
      <p class="text-gray-600 mb-8 max-w-md mx-auto">Start a new conversation to ask questions about your documents and get AI-powered insights.</p>
      <div class="flex justify-center">
        <%= link_to new_chat_session_path, class: "inline-flex items-center px-6 py-3 border border-transparent text-sm font-medium rounded-xl text-white bg-gradient-to-r from-blue-600 to-blue-700 hover:from-blue-700 hover:to-blue-800 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200 shadow-sm hover:shadow-md" do %>
          <svg class="h-5 w-5 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
          </svg>
          Start Your First Chat
        <% end %>
      </div>
    </div>
  <% end %>
</div>
