<div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
  <!-- Header Section -->
  <div class="mb-8">
    <div class="flex items-center justify-between">
      <div class="flex-1">
        <nav class="flex mb-4" aria-label="Breadcrumb">
          <ol class="flex items-center space-x-3">
            <li>
              <%= link_to chat_sessions_path, class: "text-gray-500 hover:text-gray-700 transition-colors duration-200 flex items-center space-x-1" do %>
                <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                  <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
                </svg>
                <span class="text-sm font-medium">Chat Sessions</span>
              <% end %>
            </li>
            <li>
              <div class="flex items-center space-x-3">
                <svg class="w-4 h-4 text-gray-300" fill="currentColor" viewBox="0 0 20 20">
                  <path fill-rule="evenodd" d="M7.293 14.707a1 1 0 010-1.414L10.586 10 7.293 6.707a1 1 0 011.414-1.414l4 4a1 1 0 010 1.414l-4 4a1 1 0 01-1.414 0z" clip-rule="evenodd" />
                </svg>
                <span class="text-sm font-medium text-gray-700"><%= @chat_session.title %></span>
              </div>
            </li>
          </ol>
        </nav>
        <h1 class="text-3xl font-bold text-gray-900 mb-2"><%= @chat_session.title %></h1>
        <p class="text-gray-600 text-lg">AI-powered conversation about your documents</p>
      </div>
      <div class="flex items-center space-x-3 ml-6">
        <%= link_to chat_sessions_path, class: "inline-flex items-center px-4 py-2 border border-gray-300 shadow-sm text-sm font-medium rounded-xl text-gray-700 bg-white hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-blue-500 transition-all duration-200" do %>
          <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path>
          </svg>
          Back to Chats
        <% end %>
        <%= link_to chat_session_path(@chat_session), method: :delete, data: { confirm: "Are you sure you want to delete this chat session?" }, class: "inline-flex items-center px-4 py-2 border border-transparent text-sm font-medium rounded-xl text-white bg-red-600 hover:bg-red-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-red-500 transition-all duration-200" do %>
          <svg class="h-4 w-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16"></path>
          </svg>
          Delete Chat
        <% end %>
      </div>
    </div>
  </div>

  <!-- Chat Container -->
  <div class="bg-white shadow-xl rounded-2xl border border-gray-100 overflow-hidden">
    <!-- Chat Messages -->
    <div id="chat_messages" class="h-[600px] overflow-y-auto p-6 space-y-6">
      <% if @chat_messages.any? %>
        <% @chat_messages.each do |message| %>
          <div class="flex <%= message.role == 'user' ? 'justify-end' : 'justify-start' %>">
            <div class="max-w-2xl <%= message.role == 'user' ? 'bg-gradient-to-br from-blue-600 to-blue-700 text-white' : 'bg-gray-50 text-gray-900 border border-gray-200' %> rounded-2xl px-6 py-4 shadow-sm">
              <div class="flex items-center space-x-3 mb-3">
                <div class="w-8 h-8 rounded-full flex items-center justify-center <%= message.role == 'user' ? 'bg-blue-500/20' : 'bg-gray-200' %>">
                  <% if message.role == 'user' %>
                    <svg class="w-4 h-4 text-white" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M10 9a3 3 0 100-6 3 3 0 000 6zm-7 9a7 7 0 1114 0H3z" clip-rule="evenodd" />
                    </svg>
                  <% else %>
                    <svg class="w-4 h-4 text-gray-600" fill="currentColor" viewBox="0 0 20 20">
                      <path fill-rule="evenodd" d="M18 10a8 8 0 11-16 0 8 8 0 0116 0zm-6-3a2 2 0 11-4 0 2 2 0 014 0zm-2 4a5 5 0 00-4.546 2.916A5.986 5.986 0 0010 16a5.986 5.986 0 004.546-2.084A5 5 0 0010 11z" clip-rule="evenodd" />
                    </svg>
                  <% end %>
                </div>
                <div>
                  <div class="font-semibold text-sm">
                    <%= message.role == 'user' ? 'You' : 'AI Assistant' %>
                  </div>
                  <div class="text-xs opacity-75">
                    <%= message.created_at.strftime("%I:%M %p") %>
                  </div>
                </div>
              </div>
              <div class="prose prose-sm max-w-none">
                <div class="whitespace-pre-wrap leading-relaxed"><%= message.content %></div>
              </div>
              <% if message.metadata&.dig('sources')&.any? %>
                <div class="mt-4 pt-4 border-t border-gray-300/30">
                  <div class="text-xs font-medium opacity-75 mb-2">Sources:</div>
                  <div class="text-xs opacity-75 space-y-1">
                    <% message.metadata['sources'].each do |source| %>
                      <div class="flex items-center space-x-2">
                        <svg class="w-3 h-3" fill="currentColor" viewBox="0 0 20 20">
                          <path fill-rule="evenodd" d="M4 4a2 2 0 012-2h4.586A2 2 0 0112 2.586L15.414 6A2 2 0 0116 7.414V16a2 2 0 01-2 2H6a2 2 0 01-2-2V4zm2 6a1 1 0 011-1h6a1 1 0 110 2H7a1 1 0 01-1-1zm1 3a1 1 0 100 2h6a1 1 0 100-2H7z" clip-rule="evenodd" />
                        </svg>
                        <span><%= source %></span>
                      </div>
                    <% end %>
                  </div>
                </div>
              <% end %>
            </div>
          </div>
        <% end %>
      <% else %>
        <div class="text-center py-16">
          <div class="w-16 h-16 bg-gradient-to-br from-blue-100 to-blue-200 rounded-full flex items-center justify-center mx-auto mb-4">
            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
            </svg>
          </div>
          <h3 class="text-lg font-semibold text-gray-900 mb-2">Start your conversation</h3>
          <p class="text-gray-600">Ask a question about your documents below to get started.</p>
        </div>
      <% end %>
    </div>

    <!-- Chat Input -->
    <div class="border-t border-gray-200 bg-gray-50/50 p-6">
      <div id="chat_form">
        <%= render "chat_messages/form", chat_session: @chat_session, chat_message: ChatMessage.new %>
      </div>
    </div>
  </div>

  <!-- Document Collections Info -->
  <% if @chat_session.document_collection %>
    <div class="mt-8 bg-white rounded-xl border border-gray-200 p-6 shadow-sm">
      <div class="flex items-center space-x-3 mb-4">
        <div class="w-10 h-10 bg-gradient-to-br from-blue-100 to-blue-200 rounded-lg flex items-center justify-center">
          <svg class="w-5 h-5 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10"></path>
          </svg>
        </div>
        <div>
          <h3 class="text-lg font-semibold text-gray-900">Using documents from</h3>
          <p class="text-gray-600">This conversation is powered by your document collection</p>
        </div>
      </div>
      <div class="flex items-center space-x-3">
        <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
          <%= @chat_session.document_collection.name %>
        </span>
        <span class="text-sm text-gray-500">
          <%= pluralize(@chat_session.document_collection.documents.count, 'document') %>
        </span>
      </div>
    </div>
  <% end %>
</div>

<script>
  // Auto-scroll to bottom of chat messages
  const chatMessages = document.getElementById('chat_messages');
  if (chatMessages) {
    chatMessages.scrollTop = chatMessages.scrollHeight;
  }
</script>
