<% content_for :main_class, "min-h-screen" %>

<div class="flex h-screen bg-gray-50">
  <!-- Main Chat Area -->
  <div class="flex-1 flex flex-col min-w-0">
    <!-- Chat Header -->
    <div class="bg-white border-b border-gray-200 px-6 py-4 flex-shrink-0">
      <div class="flex items-center justify-between">
        <div class="flex-1">
          <h1 class="text-xl font-semibold text-gray-900 chat-title">
            <% if @chat_session.title.present? %>
              <%= @chat_session.title %>
            <% else %>
              <span class="text-gray-400 italic">Generating title...</span>
            <% end %>
          </h1>
          <p class="text-sm text-gray-600">AI-powered conversation about your documents</p>
        </div>
        <div class="flex items-center space-x-3">
          <% if @chat_session.document_collection %>
            <span class="inline-flex items-center px-3 py-1 rounded-full text-sm font-medium bg-blue-100 text-blue-800">
              <%= @chat_session.document_collection.name %>
            </span>
          <% end %>
        </div>
      </div>
    </div>

    <!-- Chat Messages -->
    <div class="flex-1 overflow-hidden min-h-0">
      <div id="chat_messages" class="h-full overflow-y-auto overflow-x-hidden p-6 space-y-6">
        <%= render partial: "chat_sessions/messages", locals: { chat_messages: @chat_messages } %>
      </div>
    </div>

    <!-- Chat Input -->
    <div class="bg-white border-t border-gray-200 px-6 py-4 flex-shrink-0" id="chat_form">
      <%= render "chat_messages/form", chat_session: @chat_session, chat_message: @chat_message %>
    </div>
  </div>

<script>
  // Auto-scroll to bottom of chat messages
  (function() {
    const chatMessages = document.getElementById('chat_messages');
    if (chatMessages) {
      chatMessages.scrollTop = chatMessages.scrollHeight;
    }
  })();

  // Poll for title updates if current chat has no title
  <% if @chat_session.title.blank? %>
    const pollForTitle = setInterval(function() {
      fetch(`/chat_sessions/<%= @chat_session.id %>`)
        .then(response => response.text())
        .then(html => {
          const parser = new DOMParser();
          const doc = parser.parseFromString(html, 'text/html');
          const titleElement = doc.querySelector('.chat-title');
          if (titleElement && titleElement.textContent.trim() !== 'Generating title...') {
            // Title has been generated, update the page
            location.reload();
            clearInterval(pollForTitle);
          }
        })
        .catch(error => {
          console.error('Error polling for title:', error);
        });
    }, 3000); // Check every 3 seconds

    // Stop polling after 30 seconds
    setTimeout(function() {
      clearInterval(pollForTitle);
    }, 30000);
  <% end %>
</script>

<%= turbo_stream_from "chat_session_#{@chat_session.id}" %>
